# ============================================
# Environment Configuration for SCRS Backend
# ============================================

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_DATABASE=scrs

# JWT Configuration
JWT_SECRET=scrs_dev_secret_change_in_production

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# AI Provider Fallback Configuration
# Priority order at runtime: Groq -> OpenRouter -> OpenAI

# Groq (Primary)
GROQ_API_KEYS=your-groq-key-1,your-groq-key-2
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (Backup)
OPENROUTER_API_KEYS=your-openrouter-key-1,your-openrouter-key-2
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=SCRS

# OpenAI (Optional backup)
OPENAI_API_KEYS=your-openai-key-1,your-openai-key-2
OPENAI_MODEL=gpt-4o-mini

# Legacy single-key compatibility (optional)
# OPENAI_API_KEY=sk-your-openai-key-here

# Server Configuration
PORT=5000
NODE_ENV=development
